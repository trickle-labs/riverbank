# ─── Database ────────────────────────────────────────────────────────────────
RIVERBANK_DB__DSN=postgresql+psycopg://riverbank:riverbank@localhost:5432/riverbank

# ─── LLM provider (default: local Ollama, no API key required) ───────────────
RIVERBANK_LLM__PROVIDER=ollama
RIVERBANK_LLM__API_BASE=http://localhost:11434/v1
RIVERBANK_LLM__API_KEY=ollama
RIVERBANK_LLM__MODEL=llama3.2
RIVERBANK_LLM__EMBED_MODEL=nomic-embed-text

# ── To use OpenAI instead: ───────────────────────────────────────────────────
# RIVERBANK_LLM__PROVIDER=openai
# RIVERBANK_LLM__API_BASE=https://api.openai.com/v1
# RIVERBANK_LLM__API_KEY=sk-...
# RIVERBANK_LLM__MODEL=gpt-4o-mini
# RIVERBANK_LLM__EMBED_MODEL=text-embedding-3-small

# ── To use Anthropic instead: ────────────────────────────────────────────────
# RIVERBANK_LLM__PROVIDER=anthropic
# RIVERBANK_LLM__API_KEY=sk-ant-...
# RIVERBANK_LLM__MODEL=claude-3-5-haiku-20241022

# ── To use a local vLLM server: ──────────────────────────────────────────────
# RIVERBANK_LLM__PROVIDER=vllm
# RIVERBANK_LLM__API_BASE=http://localhost:8000/v1
# RIVERBANK_LLM__API_KEY=token-abc
# RIVERBANK_LLM__MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ─── Langfuse observability (optional) ───────────────────────────────────────
# RIVERBANK_LANGFUSE__ENABLED=true
# RIVERBANK_LANGFUSE__PUBLIC_KEY=pk-lf-...
# RIVERBANK_LANGFUSE__SECRET_KEY=sk-lf-...
# RIVERBANK_LANGFUSE__HOST=http://localhost:3000

# ─── Override config file location (default: ~/.riverbank/config.toml) ───────
# RIVERBANK_CONFIG_FILE=/path/to/config.toml
